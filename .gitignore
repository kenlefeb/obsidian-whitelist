# vscode
.vscode

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Distribution zips produced by `npm run package` are build artifacts,
# not source. They are re-created on demand and should never be committed.
*.zip

# Local tooling state — vexp indexer and memsearch session memory.
# These are per-machine runtime artifacts and should never be committed.
.vexp/
.memsearch/

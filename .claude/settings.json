{
  "permissions": {
    "allow": [
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(bun:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(gh api:*)",
      "Bash(mkdir:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Write(ai-docs/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(.claude/**)",
      "Edit(ai-docs/**)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(.claude/**)",
      "Edit(package.json)",
      "Edit(tsconfig.json)",
      "Edit(vitest.config.ts)",
      "Skill(self-commenting)",
      "Skill(feature-analyzer)",
      "Skill(sequential-thinking)",
      "Skill(context7)",
      "Skill(code-analyzer)",
      "Skill(figma-design-extraction)",
      "Skill(figma-design-generate)",
      "Skill(frontend-playwright)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials.json)",
      "Read(./**/*_rsa)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  },
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "context7",
    "sequential-thinking",
    "playwright",
    "figma"
  ],
  "includeCoAuthoredBy": true,
  "autoMemoryEnabled": true
}